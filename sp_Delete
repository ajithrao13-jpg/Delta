WITH cte AS
(
    SELECT *,
           ROW_NUMBER() OVER (ORDER BY load_timestamp DESC) AS rn
    FROM dbo.RAW_CLN_AFS_TAKEDOWN
)
DELETE FROM cte
WHERE rn > 1000;




DELETE FROM dbo.RAW_CLN_AFS_TAKEDOWN
WHERE ID NOT IN
(
    SELECT TOP 1000 ID
    FROM dbo.RAW_CLN_AFS_TAKEDOWN
    ORDER BY ID DESC
);
