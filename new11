-------hash registry-----
CREATE TABLE dbo.hash_registry
(
    entity_name        VARCHAR(100) NOT NULL,
    row_hash           VARBINARY(32) NOT NULL,
    created_timestamp  DATETIME2(7) NOT NULL DEFAULT SYSUTCDATETIME(),
    updated_timestamp  DATETIME2(7) NOT NULL DEFAULT SYSUTCDATETIME()
);
GO

CREATE UNIQUE INDEX UX_hash_registry
ON dbo.hash_registry (entity_name, row_hash);
GO
