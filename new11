    [tkdnhlfbank] VARCHAR(2) NULL,
    [tkdnhlfoblr] VARCHAR(10) NULL,
    [tkdnhlfobln] VARCHAR(10) NULL,
    [PACKAGE_ID] BIGINT NOT NULL,
