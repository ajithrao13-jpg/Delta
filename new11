-------------SP---------------------------
CREATE OR ALTER PROCEDURE dbo.sp_process_cln_takedown
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @entity_name VARCHAR(100) = 'cln_takedown';
    DECLARE @current_timestamp DATETIME2(7) = SYSUTCDATETIME();

    ------------------------------------------------
    -- STEP 1 : First batch handling
    ------------------------------------------------
    IF NOT EXISTS
    (
        SELECT 1
        FROM dbo.hash_registry
        WHERE entity_name = @entity_name
    )
    BEGIN
        -- Insert all staging rows into target
        INSERT INTO dbo.cln_takedown_target
        (
            tkdnloanbank,
            tkdnloanoblr,
            tkdnloanobln,
            tkdnloantypes,
            tkdnloantkdnlvl,
            tkdnhlfbank,
            tkdnhlfoblr,
            tkdnhlfobln,
            PACKAGE_ID,
            STAGING_ID,
            SYSTEM_DATETIME
        )
        SELECT
            s.tkdnloanbank,
            s.tkdnloanoblr,
            s.tkdnloanobln,
            s.tkdnloantypes,
            s.tkdnloantkdnlvl,
            s.tkdnhlfbank,
            s.tkdnhlfoblr,
            s.tkdnhlfobln,
            s.PACKAGE_ID,
            s.STAGING_ID,
            s.SYSTEM_DATETIME
        FROM dbo.cln_takedown_staging s;

        -- Insert all hashes into registry
        INSERT INTO dbo.hash_registry
        (
            entity_name,
            row_hash,
            created_timestamp,
            updated_timestamp
        )
        SELECT DISTINCT
            @entity_name,
            HASHBYTES
            (
                'SHA2_256',
                CONCAT(
                    ISNULL(s.tkdnloanbank, ''), '|',
                    ISNULL(s.tkdnloanoblr, ''), '|',
                    ISNULL(s.tkdnloanobln, ''), '|',
                    ISNULL(s.tkdnloantypes, ''), '|',
                    ISNULL(s.tkdnloantkdnlvl, ''), '|',
                    ISNULL(s.tkdnhlfbank, ''), '|',
                    ISNULL(s.tkdnhlfoblr, ''), '|',
                    ISNULL(s.tkdnhlfobln, '')
                )
            ),
            @current_timestamp,
            @current_timestamp
        FROM dbo.cln_takedown_staging s;

        RETURN;
    END;

    ------------------------------------------------
    -- STEP 2 : Insert new / changed rows into target
    ------------------------------------------------
    INSERT INTO dbo.cln_takedown_target
    (
        tkdnloanbank,
        tkdnloanoblr,
        tkdnloanobln,
        tkdnloantypes,
        tkdnloantkdnlvl,
        tkdnhlfbank,
        tkdnhlfoblr,
        tkdnhlfobln,
        PACKAGE_ID,
        STAGING_ID,
        SYSTEM_DATETIME
    )
    SELECT
        s.tkdnloanbank,
        s.tkdnloanoblr,
        s.tkdnloanobln,
        s.tkdnloantypes,
        s.tkdnloantkdnlvl,
        s.tkdnhlfbank,
        s.tkdnhlfoblr,
        s.tkdnhlfobln,
        s.PACKAGE_ID,
        s.STAGING_ID,
        s.SYSTEM_DATETIME
    FROM dbo.cln_takedown_staging s
    LEFT JOIN dbo.hash_registry hr
        ON hr.entity_name = @entity_name
       AND hr.row_hash = HASHBYTES
            (
                'SHA2_256',
                CONCAT(
                    ISNULL(s.tkdnloanbank, ''), '|',
                    ISNULL(s.tkdnloanoblr, ''), '|',
                    ISNULL(s.tkdnloanobln, ''), '|',
                    ISNULL(s.tkdnloantypes, ''), '|',
                    ISNULL(s.tkdnloantkdnlvl, ''), '|',
                    ISNULL(s.tkdnhlfbank, ''), '|',
                    ISNULL(s.tkdnhlfoblr, ''), '|',
                    ISNULL(s.tkdnhlfobln, '')
                )
            )
    WHERE hr.row_hash IS NULL;

    ------------------------------------------------
    -- STEP 3 : Insert new hashes into registry
    ------------------------------------------------
    INSERT INTO dbo.hash_registry
    (
        entity_name,
        row_hash,
        created_timestamp,
        updated_timestamp
    )
    SELECT DISTINCT
        @entity_name,
        HASHBYTES
        (
            'SHA2_256',
            CONCAT(
                ISNULL(s.tkdnloanbank, ''), '|',
                ISNULL(s.tkdnloanoblr, ''), '|',
                ISNULL(s.tkdnloanobln, ''), '|',
                ISNULL(s.tkdnloantypes, ''), '|',
                ISNULL(s.tkdnloantkdnlvl, ''), '|',
                ISNULL(s.tkdnhlfbank, ''), '|',
                ISNULL(s.tkdnhlfoblr, ''), '|',
                ISNULL(s.tkdnhlfobln, '')
            )
        ),
        @current_timestamp,
        @current_timestamp
    FROM dbo.cln_takedown_staging s
    LEFT JOIN dbo.hash_registry hr
        ON hr.entity_name = @entity_name
       AND hr.row_hash = HASHBYTES
            (
                'SHA2_256',
                CONCAT(
                    ISNULL(s.tkdnloanbank, ''), '|',
                    ISNULL(s.tkdnloanoblr, ''), '|',
                    ISNULL(s.tkdnloanobln, ''), '|',
                    ISNULL(s.tkdnloantypes, ''), '|',
                    ISNULL(s.tkdnloantkdnlvl, ''), '|',
                    ISNULL(s.tkdnhlfbank, ''), '|',
                    ISNULL(s.tkdnhlfoblr, ''), '|',
                    ISNULL(s.tkdnhlfobln, '')
                )
            )
    WHERE hr.row_hash IS NULL;

    ------------------------------------------------
    -- STEP 4 : Update timestamp for unchanged hashes
    ------------------------------------------------
    UPDATE hr
    SET hr.updated_timestamp = @current_timestamp
    FROM dbo.hash_registry hr
    INNER JOIN dbo.cln_takedown_staging s
        ON hr.entity_name = @entity_name
       AND hr.row_hash = HASHBYTES
            (
                'SHA2_256',
                CONCAT(
                    ISNULL(s.tkdnloanbank, ''), '|',
                    ISNULL(s.tkdnloanoblr, ''), '|',
                    ISNULL(s.tkdnloanobln, ''), '|',
                    ISNULL(s.tkdnloantypes, ''), '|',
                    ISNULL(s.tkdnloantkdnlvl, ''), '|',
                    ISNULL(s.tkdnhlfbank, ''), '|',
                    ISNULL(s.tkdnhlfoblr, ''), '|',
                    ISNULL(s.tkdnhlfobln, '')
                )
            );

    ------------------------------------------------
    -- STEP 5 : Delete hashes not seen in current batch
    ------------------------------------------------
    DELETE FROM dbo.hash_registry
    WHERE entity_name = @entity_name
      AND updated_timestamp < @current_timestamp;

END;
GO
